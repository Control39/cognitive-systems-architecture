{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arch Compass Configuration Schema",
  "type": "object",
  "properties": {
    "framework": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Название фреймворка"
        },
        "version": {
          "type": "string",
          "description": "Версия фреймворка"
        },
        "debug": {
          "type": "boolean",
          "description": "Режим отладки"
        }
      }
    },
    "ai": {
      "type": "object",
      "properties": {
        "openai": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "Ключ API OpenAI"
            },
            "model": {
              "type": "string",
              "description": "Модель OpenAI для использования"
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Температура генерации"
            }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "prometheus": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string",
              "format": "uri",
              "description": "Конечная точка Prometheus"
            },
            "jobName": {
              "type": "string",
              "description": "Имя задания Prometheus"
            }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "encryptionKey": {
          "type": "string",
          "description": "Ключ шифрования для менеджера секретов"
        }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Уровень логирования"
        },
        "file": {
          "type": "string",
          "description": "Путь к файлу логов"
        }
      }
    }
  }
}