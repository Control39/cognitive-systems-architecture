{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "python.defaultInterpreterPath": "python3",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.indexing": true,
    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Args": [
        "--max-line-length=88"
    ],
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": [
        "--line-length",
        "88"
    ],
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/*.pyo": true,
        "**/*.pyd": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/*.log": true,
        "**/.env": false,
        "**/.vscode": false,
        "**/.idea": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    },
    "files.encoding": "utf8",
    "files.eol": "\n",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        }
    },
    "terminal.integrated.copyOnSelection": false,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "workbench.colorTheme": "Default Dark+",
    "editor.fontSize": 14,
    "editor.lineHeight": 1.5,
    "editor.renderWhitespace": "boundary",
    "editor.guides.bracketPairs": true,
    "editor.guides.bracketPairsHorizontal": true,
    "breadcrumbs.enabled": true,
    "editor.stickyScroll.enabled": true,
    "search.useIgnoreFiles": true,
    "search.quickOpen.includeSymbols": true,
    "git.autofetch": true,
    "git.blame.editorDecoration.enabled": true,
    "git.confirmSync": false,
    "telemetry.telemetryLevel": "off",
    "telemetry.editStats.enabled": false,
    "redhat.telemetry.enabled": false,
    "workbench.editor.enablePreview": false,
    "workbench.browser.openLocalhostLinks": true,
    "editor.codeActions.triggerOnFocusChange": true,
    "continue.enableConsole": true,
    "continue.enableQuickActions": true,
    "sourcecraft-code-assist.allowedCommands": [
        "git log",
        "git diff",
        "git show",
        "git commit",
        "git push",
        "git pull",
        "git status",
        "git add",
        "python",
        "python3",
        "pip",
        "pip install",
        "streamlit",
        "docker",
        "docker build",
        "docker run",
        "docker-compose",
        "pytest",
        "cd",
        "echo",
        "code",
        "npm",
        "npx",
        "ollama",
        "ollama run",
        "ollama list",
        "ollama pull",
        "ollama serve"
    ],
    "sourcecraft-code-assist.deniedCommands": [],
    "sourcecraft-code-assist.embeddingProvider": {
        "name": "yandex",
        "apiKey": "${env:YANDEX_API_KEY}",
        "baseURL": "https://ai.api.cloud.yandex.net/v1",
        "model": "yandex/sts",
        "dimension": 1024,
        "vectorStore": {
            "type": "qdrant",
            "url": "http://localhost:6333",
            "collectionName": "sourcecraft_context"
        }
    },
    "sourcecraft-code-assist.vsCodeLmModelSelector": {
        "strategy": "sequential",
        "timeout": 30000,
        "retryCount": 2,
        "providers": [
            {
                "name": "yandex",
                "apiKey": "${env:YANDEX_API_KEY}",
                "folderId": "${env:YANDEX_FOLDER_ID}",
                "models": [
                    {
                        "id": "gpt://${env:YANDEX_FOLDER_ID}/yandexgpt/latest",
                        "name": "YandexGPT Pro",
                        "reasoningMode": "ENABLED_HIDDEN",
                        "priority": 1,
                        "temperature": 0.3,
                        "maxTokens": 8000
                    },
                    {
                        "id": "gpt://${env:YANDEX_FOLDER_ID}/yandexgpt-lite/latest",
                        "name": "YandexGPT Lite",
                        "reasoningMode": "DISABLED",
                        "priority": 2,
                        "temperature": 0.5,
                        "maxTokens": 4000
                    }
                ]
            },
            {
                "name": "openrouter",
                "apiKey": "${env:OPENROUTER_API_KEY}",
                "baseURL": "https://openrouter.ai/api/v1",
                "models": [
                    {
                        "id": "google/gemini-2.0-flash-exp:free",
                        "name": "Gemini Flash",
                        "priority": 3,
                        "temperature": 0.3,
                        "maxTokens": 8000
                    },
                    {
                        "id": "meta-llama/llama-3.2-3b-instruct:free",
                        "name": "Llama 3.2",
                        "priority": 4,
                        "temperature": 0.3,
                        "maxTokens": 4000
                    }
                ]
            },
            {
                "name": "ollama",
                "apiKey": "dummy",
                "baseURL": "http://localhost:11434/v1",
                "models": [
                    {
                        "id": "qwen2.5-coder:3b",
                        "name": "Qwen Coder 3B",
                        "priority": 5,
                        "temperature": 0.3,
                        "maxTokens": 4096
                    },
                    {
                        "id": "gemma3:4b",
                        "name": "Gemma 3 4B",
                        "priority": 6,
                        "temperature": 0.3,
                        "maxTokens": 4096
                    },
                    {
                        "id": "llama3.2:1b",
                        "name": "Llama 3.2 1B",
                        "priority": 7,
                        "temperature": 0.3,
                        "maxTokens": 2048
                    }
                ]
            }
        ]
    },
    "koda.enableTabAutocomplete": true,
    "koda.controlPlaneEnvironment": "staging",
    "yaml.schemas": {
        "file:///c%3A/Users/Z/.vscode/extensions/continue.continue-1.3.32-win32-x64/config-yaml-schema.json": [
            ".continue/**/*.yaml"
        ]
    },
    "settingsSync.ignoredExtensions": [],
    "settingsSync.ignoredSettings": [],
    "extensions.autoUpdate": true,
    "extensions.autoCheckUpdates": true,
    "update.mode": "default",
    "window.zoomLevel": 0,
    "window.restoreWindows": "preserve",
    "security.workspace.trust.enabled": true,
    "security.workspace.trust.startupPrompt": "once",
    "editor.minimap.enabled": true,
    "editor.wordWrap": "off",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.rulers": [
        88,
        120
    ],
    "diffEditor.ignoreTrimWhitespace": false,
    "explorer.confirmDelete": true,
    "explorer.confirmDragAndDrop": true,
    "workbench.list.openMode": "singleClick",
    "workbench.tree.enableStickyScroll": true,
    "notebook.output.textLineLimit": 30,
    "markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",
    "markdown.preview.fontSize": 14,
    "markdown.preview.lineHeight": 1.5,
    "markdown.styles": [],
    "markdown.extension.toc.levels": "1..6",
    "markdown.extension.toc.orderedList": false,
    "markdown.extension.tableFormatter.enabled": true,
    "markdown.extension.mathEngine": "MathJax",
    "markdown.extension.print.theme": "auto",
    "markdown.extension.preview.initialLine": "documentTop",
    "markdown.extension.preview.scrollPreviewWithEditor": true,
    "markdown.extension.preview.scrollEditorWithPreview": true,
    "markdown.extension.editing.toolbar.enabled": true,
    "markdown.extension.editing.toggleBold.key": "Ctrl+B",
    "markdown.extension.editing.toggleItalic.key": "Ctrl+I",
    "markdown.extension.editing.toggleStrikethrough.key": "Alt+S",
    "markdown.extension.editing.toggleMath.key": "Alt+M",
    "markdown.extension.editing.toggleCode.key": "Alt+C",
    "markdown.extension.editing.toggleList.key": "Ctrl+Shift+]",
