    "markdown.extension.editing.toggleUnderline.key": "Ctrl+U",
    "markdown.extension.editing.toggleColor.key": "Alt+C",
    "markdown.extension.editing.toggleBackgroundColor.key": "Alt+B",
    "markdown.extension.editing.toggleFontSize.key": "Alt+F",
    "markdown.extension.editing.toggleFontFamily.key": "Alt+O",
    "markdown.extension.editing.toggleFontWeight.key": "Alt+W",
