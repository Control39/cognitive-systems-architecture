{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "python.analysis.typeCheckingMode": "basic",
    "sourcecraft-code-assist.allowedCommands": [
        "git log", "git diff", "git show", "git commit", "git push",
        "git pull", "git status", "git add", "python", "python3",
        "pip", "pip install", "streamlit", "docker", "docker build",
        "docker run", "docker-compose", "pytest", "cd", "echo", "code",
        "npm", "npx", "ollama", "ollama run", "ollama list",
        "ollama pull", "ollama serve"
    ],
    "sourcecraft-code-assist.embeddingProvider": {
        "name": "yandex",
        "apiKey": "${env:YANDEX_API_KEY}",
        "baseURL": "https://ai.api.cloud.yandex.net/v1",
        "model": "yandex/sts",
        "dimension": 1024,
        "vectorStore": {
            "type": "qdrant",
            "url": "http://localhost:6333",
            "collectionName": "sourcecraft_context"
        }
    },
    "sourcecraft-code-assist.vsCodeLmModelSelector": {
        "strategy": "sequential",
        "timeout": 30000,
        "retryCount": 2,
        "providers": [
            {
                "name": "ollama",
                "apiKey": "dummy",
                "baseURL": "http://localhost:11434/v1",
                "models": [
                    {
                        "id": "qwen2.5-coder:3b",
                        "name": "🐙 Qwen Coder 3B (локально)",
                        "priority": 1,
                        "temperature": 0.3,
                        "maxTokens": 4096
                    },
                    {
                        "id": "gemma3:4b",
                        "name": "🌀 Gemma 3 4B (локально)",
                        "priority": 2,
                        "temperature": 0.3,
                        "maxTokens": 4096
                    },
                    {
                        "id": "llama3.2:1b",
                        "name": "🦙 Llama 3.2 1B (локально)",
                        "priority": 3,
                        "temperature": 0.3,
                        "maxTokens": 2048
                    }
                ]
            },
            {
                "name": "yandex",
                "apiKey": "${env:YANDEX_API_KEY}",
                "folderId": "${env:YANDEX_FOLDER_ID}",
                "models": [
                    {
                        "id": "gpt://${env:YANDEX_FOLDER_ID}/yandexgpt/latest",
                        "name": "YandexGPT Pro",
                        "reasoningMode": "ENABLED_HIDDEN",
                        "priority": 4,
                        "temperature": 0.3,
                        "maxTokens": 8000
                    },
                    {
                        "id": "gpt://${env:YANDEX_FOLDER_ID}/yandexgpt-lite/latest",
                        "name": "YandexGPT Lite",
                        "reasoningMode": "DISABLED",
                        "priority": 5,
                        "temperature": 0.5,
                        "maxTokens": 4000
                    }
                ]
            },
            {
                "name": "openrouter",
                "apiKey": "${env:OPENROUTER_API_KEY}",
                "baseURL": "https://openrouter.ai/api/v1",
                "models": [
                    {
                        "id": "google/gemini-2.0-flash-exp:free",
                        "name": "✨ Gemini Flash (OpenRouter)",
                        "priority": 6,
                        "temperature": 0.3,
                        "maxTokens": 8000
                    },
                    {
                        "id": "meta-llama/llama-3.2-3b-instruct:free",
                        "name": "🦙 Llama 3.2 (OpenRouter)",
                        "priority": 7,
                        "temperature": 0.3,
                        "maxTokens": 4000
                    }
                ]
            }
        ]
    }
}